---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import SocialCard from "../components/SocialCard.astro";
import DiscordIcon from "../components/icons/DiscordIcon.astro";
import GithubIcon from "../components/icons/GithubIcon.astro";
import GitlabIcon from "../components/icons/GitlabIcon .astro";
import MatrixIcon from "../components/icons/MatrixIcon.astro";
import TwitterIcon from "../components/icons/TwitterIcon.astro";
import UnsplashIcon from "../components/icons/UnsplashIcon.astro";
import LinkedInIcon from "../components/icons/LinkedInIcon.astro";
import IMDbIcon from "../components/icons/IMDbIcon.astro";
import LastFmIcon from "../components/icons/LastFmIcon.astro";
import SteamIcon from "../components/icons/SteamIcon.astro";
import ScribdIcon from "../components/icons/ScribdIcon.astro";
---

<!doctype html>
<html lang="en" class="bg-gray-50 dark:bg-gray-900">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-screen-xl min-h-screen">
      <section>
        <div class="grid max-w-screen-xl px-4 py-8 mx-auto lg:gap-16 lg:py-20 lg:grid-cols-12">
          <div class="place-self-center lg:col-span-7">
            <h1 class="text-gray-900 dark:text-white font-bold text-4xl sm:text-5xl md:text-6xl leading-tight">
              Hi, I'm Suhas<br />Dissanayake.
            </h1>
            <div class="mt-6 space-y-3 max-w-xl">
              <p class="text-gray-600 dark:text-gray-300 text-lg sm:text-xl leading-relaxed">
                Sri Lankan code goblin. Cyber Security undergrad @ UoM.
              </p>
              <p class="text-gray-600 dark:text-gray-300 text-lg sm:text-xl leading-relaxed">
                Arch (btw). <i>If you're still using Windows in 2026, you're already cooked.</i>
              </p>
              <p class="text-gray-600 dark:text-gray-300 text-lg sm:text-xl leading-relaxed">
                Real men <code class="text-sm">git push --force</code> to main and let God sort the merge conflicts.
              </p>
              <p class="text-gray-600 dark:text-gray-300 text-lg sm:text-xl leading-relaxed">
                No RAID. No snapshots. No offsite backups. Pure LUKS full-disk encryption with a passphrase that's entirely unrecoverable if I ever get amnesia. (At least my Linux ISOs will be safe from prying eyes, I guess?)
              </p>
              <p class="text-gray-400 dark:text-gray-500 text-base italic">
                AI still can't pass my university's course, my job's safe (maximum copium)
              </p>
            </div>
          </div>
          <div class="hidden lg:block lg:col-span-5">
            <img
              class="rounded-2xl w-full object-cover shadow-lg"
              src="/my_photo.avif"
              alt="Suhas Dissanayake"
            />
          </div>
        </div>
      </section>
      <section class="pt-10 pb-10 lg:pt-40 lg:pb-20 px-4">
        <h2
          class="text-gray-600 dark:text-gray-400 text-3xl sm:text-3xl md:text-5xl"
        >
          Social Media Links
        </h2>
        <div
          class="grid grid-cols-1 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3 grid-flow-row gap-4 pt-4 sm:pt-8 w-full justify-items-center"
        >
          <SocialCard
            title={"Suhas Dissanayake"}
            subtitle={"SuhasDissa"}
            link={"https://github.com/SuhasDissa/"}
          >
            <GithubIcon />
          </SocialCard>

          <SocialCard
            title={"Suhas Dissanayake"}
            subtitle={"@suhas_d"}
            link={"https://matrix.to/#/@suhas_d:matrix.org"}
          >
            <MatrixIcon />
          </SocialCard>

          <SocialCard
            title={"Suhas Dissanayake"}
            subtitle={"SuhasDissa"}
            link={"https://github.com/SuhasDissa/"}
          >
            <TwitterIcon />
          </SocialCard>

          <SocialCard
            title={"Suhas Dissanayake"}
            subtitle={"suhasdissa"}
            link={"https://discordapp.com/users/924165265258844180"}
          >
            <DiscordIcon />
          </SocialCard>

          <SocialCard
            title={"Suhas Dissanayake"}
            subtitle={"@suhasdissa"}
            link={"https://unsplash.com/@suhasdissa"}
          >
            <UnsplashIcon />
          </SocialCard>

          <SocialCard
            title={"Suhas Dissanayake"}
            subtitle={"SuhasDissa"}
            link={"https://gitlab.com/SuhasDissa"}
          >
            <GitlabIcon />
          </SocialCard>

          <SocialCard
          title={"Suhas Dissanayake"}
          subtitle={"SuhasDissa"}
          link={"https://www.linkedin.com/in/suhasdissa/"}
        >
          <LinkedInIcon />
        </SocialCard>

          <SocialCard
            title={"Suhas Dissanayake"}
            subtitle={"suhasdissa"}
            link={"https://www.imdb.com/user/p.obl7nn6ms7povh42nvdlixog64/ratings"}
          >
            <IMDbIcon />
          </SocialCard>

          <SocialCard
            title={"Suhas Dissanayake"}
            subtitle={"suhasdissa"}
            link={"https://www.last.fm/user/suhasdissa"}
          >
            <LastFmIcon />
          </SocialCard>

          <SocialCard
            title={"Suhas Dissanayake"}
            subtitle={"suhasdissa"}
            link={"https://steamcommunity.com/id/suhasdissa/"}
          >
            <SteamIcon />
          </SocialCard>

          <SocialCard
            title={"Suhas Dissanayake"}
            subtitle={"suhasdissa"}
            link={"https://www.scribd.com/suhasdissa"}
          >
            <ScribdIcon />
          </SocialCard>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
